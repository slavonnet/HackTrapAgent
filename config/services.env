# Comma-separated list of enabled honeypot services.
ENABLED_SERVICES=asterisk,ssh,telnetd,ftp,tftp,ntp,nfs,postgresql,mysql,memcached,mongodb,redis,bgp,openvpn,smb,kafka,ipsec,imap,pop3,smtp,elasticsearch,clickhouse,ad,radius,rabbitmq,rdp,snmp,snmptrap

# Comma-separated list of jails loaded by fail2ban.
FAIL2BAN_SERVICES=asterisk,ssh,telnetd,ftp,tftp,ntp,nfs,postgresql,mysql,memcached,mongodb,redis,bgp,openvpn,smb,kafka,ipsec,imap,pop3,smtp,elasticsearch,clickhouse,ad,radius,rabbitmq,rdp,snmp,snmptrap

# Asterisk service runtime configuration.
ASTERISK_PJSIP_PUBLIC_PORT=5060
ASTERISK_IAX_PUBLIC_PORT=4569
ASTERISK_MANAGER_PUBLIC_PORT=5038
ASTERISK_ARI_PUBLIC_PORT=8088
ASTERISK_RUNTIME_USER=trap
ASTERISK_TEST_LOGIN_USER=trap

# SSH service runtime configuration.
SSH_PUBLIC_PORT=22
SSH_RUNTIME_USER=trap
SSH_TEST_LOGIN_USER=root

# Telnet service runtime configuration.
TELNETD_PUBLIC_PORT=23
TELNETD_RUNTIME_USER=trap
TELNETD_TEST_LOGIN_USER=root

# FTP service runtime configuration.
FTP_PUBLIC_PORT=21
FTP_RUNTIME_USER=trap
FTP_TEST_LOGIN_USER=trap

# TFTP service runtime configuration.
TFTP_PUBLIC_PORT=2069

# NTP service runtime configuration.
NTP_PUBLIC_PORT=123

# NFS service runtime configuration.
NFS_PUBLIC_PORT=2049
NFS_ALLOWED_CLIENTS=127.0.0.1/32
NFS_LOG_LEVEL=DEBUG

# IMAP service runtime configuration.
IMAP_PUBLIC_PORT=143
IMAP_RUNTIME_USER=trap
IMAP_TEST_LOGIN_USER=trap

# POP3 service runtime configuration.
POP3_PUBLIC_PORT=110
POP3_RUNTIME_USER=trap
POP3_TEST_LOGIN_USER=trap

# SMTP service runtime configuration.
SMTP_PUBLIC_PORT=25
SMTP_RUNTIME_USER=trap
SMTP_TEST_LOGIN_USER=trap

# RabbitMQ service runtime configuration.
RABBITMQ_PUBLIC_PORT=5672
RABBITMQ_MANAGEMENT_PUBLIC_PORT=15672
RABBITMQ_RUNTIME_USER=trap
RABBITMQ_TEST_LOGIN_USER=trap
RABBITMQ_ENABLE_MANAGEMENT=false
RABBITMQ_UNSAFE_RAM_STORAGE=true
RABBITMQ_LOW_CPU_ERL_ARGS="+S 1:1 +A 2 +sbwt none +sbwtdcpu none +sbwtdio none"

# IPsec service runtime configuration (L2TP + IKEv2 in one container).
IPSEC_L2TP_PUBLIC_PORT=1701
IPSEC_IKE_PUBLIC_PORT=500
IPSEC_NATT_PUBLIC_PORT=4500
IPSEC_RUNTIME_USER=trap
IPSEC_TEST_LOGIN_USER=trap
IPSEC_ENABLE_L2TP=true
IPSEC_ENABLE_IKEV2=true

# PostgreSQL service runtime configuration.
POSTGRESQL_PUBLIC_PORT=5432
POSTGRESQL_RUNTIME_USER=trap
POSTGRESQL_TEST_LOGIN_USER=trap

# MySQL service runtime configuration.
MYSQL_PUBLIC_PORT=3306
MYSQL_RUNTIME_USER=trap
MYSQL_TEST_LOGIN_USER=root

# Memcached service runtime configuration.
MEMCACHED_PUBLIC_PORT=11211
MEMCACHED_RUNTIME_USER=trap
MEMCACHED_TEST_LOGIN_USER=trap

# MongoDB service runtime configuration.
MONGODB_PUBLIC_PORT=27017
MONGODB_RUNTIME_USER=trap
MONGODB_TEST_LOGIN_USER=trap

# Redis service runtime configuration.
REDIS_PUBLIC_PORT=6379
REDIS_RUNTIME_USER=trap
REDIS_TEST_LOGIN_USER=trap

# Elasticsearch service runtime configuration.
ELASTICSEARCH_PUBLIC_PORT=9200
ELASTICSEARCH_RUNTIME_USER=trap
ELASTICSEARCH_TEST_LOGIN_USER=trap

# ClickHouse service runtime configuration.
CLICKHOUSE_HTTP_PUBLIC_PORT=8123
CLICKHOUSE_NATIVE_PUBLIC_PORT=9000
CLICKHOUSE_RUNTIME_USER=trap
CLICKHOUSE_TEST_LOGIN_USER=trap

# BGP service runtime configuration.
BGP_PUBLIC_PORT=179
BGP_ALLOWED_PEERS=
BGP_LOCAL_ASN=65000
BGP_PEER_ASN=65001
BGP_ROUTER_ID=198.51.100.1

# OpenVPN service runtime configuration.
OPENVPN_PUBLIC_PORT=1194
OPENVPN_RUNTIME_USER=trap
OPENVPN_TEST_LOGIN_USER=trap

# SMB service runtime configuration.
SMB_PUBLIC_PORT=445
SMB_RUNTIME_USER=trap
SMB_TEST_LOGIN_USER=trap

# Kafka service runtime configuration.
KAFKA_PUBLIC_PORT=9092
KAFKA_RUNTIME_USER=trap
KAFKA_TEST_LOGIN_USER=trap

# SNMP service runtime configuration.
SNMP_PUBLIC_PORT=161
SNMP_RUNTIME_USER=trap
SNMP_TEST_V3_USER=trap

# SNMP trap service runtime configuration.
SNMPTRAP_PUBLIC_PORT=162
SNMPTRAP_RUNTIME_USER=trap
SNMPTRAP_TEST_V3_USER=trap
# RDP service runtime configuration.
RDP_PUBLIC_PORT=3389
RDP_RUNTIME_USER=trap
RDP_TEST_LOGIN_USER=trap

# RADIUS service runtime configuration.
RADIUS_PUBLIC_PORT=1812
RADIUS_RUNTIME_USER=trap
RADIUS_TEST_LOGIN_USER=trap

# Active Directory (LDAP) service runtime configuration.
AD_PUBLIC_PORT=389
AD_RUNTIME_USER=trap
AD_TEST_LOGIN_USER=trap
