# Comma-separated list of enabled honeypot services.
ENABLED_SERVICES=ssh,ftp,ntp

# Comma-separated list of jails loaded by fail2ban.
FAIL2BAN_SERVICES=ssh,ftp,ntp

# SSH service runtime configuration.
SSH_PUBLIC_PORT=2222
SSH_RUNTIME_USER=trap
SSH_TEST_LOGIN_USER=root

# FTP service runtime configuration.
FTP_PUBLIC_PORT=2121
FTP_RUNTIME_USER=trap
FTP_TEST_LOGIN_USER=trap

# NTP service runtime configuration.
NTP_PUBLIC_PORT=2123
