# Comma-separated list of enabled honeypot services.
ENABLED_SERVICES=ssh,ftp,ntp,postgresql,mysql,bgp,openvpn,l2tp,ike2,imap,pop3,smtp,rabbitmq

# Comma-separated list of jails loaded by fail2ban.
FAIL2BAN_SERVICES=ssh,ftp,ntp,postgresql,mysql,bgp,openvpn,l2tp,ike2,imap,pop3,smtp,rabbitmq

# SSH service runtime configuration.
SSH_PUBLIC_PORT=2222
SSH_RUNTIME_USER=trap
SSH_TEST_LOGIN_USER=root

# FTP service runtime configuration.
FTP_PUBLIC_PORT=2121
FTP_RUNTIME_USER=trap
FTP_TEST_LOGIN_USER=trap

# NTP service runtime configuration.
NTP_PUBLIC_PORT=2123

# IMAP service runtime configuration.
IMAP_PUBLIC_PORT=2143
IMAP_RUNTIME_USER=trap
IMAP_TEST_LOGIN_USER=trap

# POP3 service runtime configuration.
POP3_PUBLIC_PORT=2110
POP3_RUNTIME_USER=trap
POP3_TEST_LOGIN_USER=trap

# SMTP service runtime configuration.
SMTP_PUBLIC_PORT=2525
SMTP_RUNTIME_USER=trap
SMTP_TEST_LOGIN_USER=trap

# RabbitMQ service runtime configuration.
RABBITMQ_PUBLIC_PORT=5672
RABBITMQ_MANAGEMENT_PUBLIC_PORT=15672
RABBITMQ_RUNTIME_USER=trap
RABBITMQ_TEST_LOGIN_USER=trap

# L2TP service runtime configuration.
L2TP_PUBLIC_PORT=11701
L2TP_IKE_PUBLIC_PORT=15100
L2TP_NATT_PUBLIC_PORT=14501
L2TP_RUNTIME_USER=trap
L2TP_TEST_LOGIN_USER=trap

# IKEv2 service runtime configuration.
IKE2_PUBLIC_PORT=1500
IKE2_NATT_PUBLIC_PORT=14500
IKE2_RUNTIME_USER=trap
IKE2_TEST_LOGIN_USER=trap

# PostgreSQL service runtime configuration.
POSTGRESQL_PUBLIC_PORT=5432
POSTGRESQL_RUNTIME_USER=trap
POSTGRESQL_TEST_LOGIN_USER=trap

# MySQL service runtime configuration.
MYSQL_PUBLIC_PORT=3306
MYSQL_RUNTIME_USER=trap
MYSQL_TEST_LOGIN_USER=root

# BGP service runtime configuration.
BGP_PUBLIC_PORT=2179
BGP_ALLOWED_PEERS=

# OpenVPN service runtime configuration.
OPENVPN_PUBLIC_PORT=1194
OPENVPN_RUNTIME_USER=trap
