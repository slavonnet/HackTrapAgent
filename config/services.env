# Comma-separated list of enabled honeypot services.
ENABLED_SERVICES=ssh,telnetd,ftp,ntp,nfs,postgresql,mysql,redis,bgp,openvpn,l2tp,ike2,imap,pop3,smtp,elasticsearch,ad,radius,rabbitmq,rdp,snmp,snmptrap

# Comma-separated list of jails loaded by fail2ban.
FAIL2BAN_SERVICES=ssh,telnetd,ftp,ntp,nfs,postgresql,mysql,redis,bgp,openvpn,l2tp,ike2,imap,pop3,smtp,elasticsearch,ad,radius,rabbitmq,rdp,snmp,snmptrap

# SSH service runtime configuration.
SSH_PUBLIC_PORT=2222
SSH_RUNTIME_USER=trap
SSH_TEST_LOGIN_USER=root

# Telnet service runtime configuration.
