# Comma-separated list of enabled honeypot services.
ENABLED_SERVICES=ssh,ftp,postgresql,mysql,bgp,openvpn

# Comma-separated list of jails loaded by fail2ban.
FAIL2BAN_SERVICES=ssh,ftp,postgresql,mysql,bgp,openvpn

# SSH service runtime configuration.
SSH_PUBLIC_PORT=2222
SSH_RUNTIME_USER=trap
SSH_TEST_LOGIN_USER=root

# FTP service runtime configuration.
FTP_PUBLIC_PORT=2121
FTP_RUNTIME_USER=trap
FTP_TEST_LOGIN_USER=trap

# PostgreSQL service runtime configuration.
POSTGRESQL_PUBLIC_PORT=5432
POSTGRESQL_RUNTIME_USER=trap
POSTGRESQL_TEST_LOGIN_USER=trap

# MySQL service runtime configuration.
MYSQL_PUBLIC_PORT=3306
MYSQL_RUNTIME_USER=trap
MYSQL_TEST_LOGIN_USER=root

# BGP service runtime configuration.
BGP_PUBLIC_PORT=2179
BGP_ALLOWED_PEERS=

# OpenVPN service runtime configuration.
OPENVPN_PUBLIC_PORT=1194
OPENVPN_RUNTIME_USER=trap
OPENVPN_TEST_LOGIN_USER=trap
