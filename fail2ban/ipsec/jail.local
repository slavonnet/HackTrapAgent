[ipsec-l2tp]
enabled = true
port = 500,4500
protocol = udp
filter = strongswan_ikev1
logpath = /var/log/ipsec/charon.log
findtime = 600
bantime = 3600
maxretry = 3

[ipsec-ikev2]
enabled = true
port = 500,4500
protocol = udp
filter = strongswan_ikev2
logpath = /var/log/ipsec/charon.log
findtime = 600
bantime = 3600
maxretry = 3
